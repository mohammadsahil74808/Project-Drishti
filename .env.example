# ============================================================
# SentinelX AI — Environment Variable Template
# Copy this file to `.env` and fill in values. Never commit `.env`.
# ============================================================

# ---- App ----
APP_ENV=development
APP_NAME=SentinelX AI
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_DEBUG=true

# ---- Database (PostgreSQL + PostGIS) ----
POSTGRES_USER=sentinelx
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sentinelx_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://sentinelx:change-me@db:5432/sentinelx_db

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---- Auth ----
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_MAPBOX_TOKEN=get-a-free-token-from-mapbox.com

# ---- AI / ML (all free/open-source, no paid keys required by default) ----
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=./data/faiss_index

# ---- Optional: only needed if you wire an LLM provider with a free tier ----
# LLM_API_KEY=
# LLM_PROVIDER=
